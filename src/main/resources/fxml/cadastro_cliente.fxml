<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.ifpb.ads.foodjava.view.fxml.CadastroClienteController"
      stylesheets="@../css/estilo.css"
      prefWidth="800" prefHeight="600" spacing="0">

    <HBox styleClass="header-bar" alignment="CENTER_LEFT">
        <Label text="🍴 FoodJava  —  Cadastro"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="12" maxWidth="420">
            <padding><Insets top="30" right="60" bottom="30" left="60"/></padding>

            <Label text="Dados pessoais" styleClass="titulo-secao"/>

            <TextField     fx:id="tfNome"      promptText="Nome completo *"                      styleClass="text-field"/>
            <TextField     fx:id="tfEmail"     promptText="E-mail *"                             styleClass="text-field"/>
            <PasswordField fx:id="tfSenha"     promptText="Senha (mín. 8 chars + 1 número) *"   styleClass="password-field"/>
            <TextField     fx:id="tfCpf"       promptText="CPF *"                               styleClass="text-field"/>
            <TextField     fx:id="tfTelefone"  promptText="Telefone"                            styleClass="text-field"/>
            <TextField     fx:id="tfEndereco"  promptText="Endereço"                            styleClass="text-field"/>

            <Separator/>

            <Button text="Cadastrar" styleClass="btn-primary" maxWidth="Infinity"
                    onAction="#cadastrar"/>
            <Button text="← Voltar ao Login" styleClass="btn-secondary" maxWidth="Infinity"
                    onAction="#voltarLogin"/>
        </VBox>
    </ScrollPane>
</VBox>
