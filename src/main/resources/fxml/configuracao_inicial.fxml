<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.ifpb.ads.foodjava.view.fxml.ConfiguracaoInicialController"
      stylesheets="@../css/estilo.css"
      prefWidth="800" prefHeight="600" spacing="0">

    <!-- Cabeçalho -->
    <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="8">
        <Label text="🍴 FoodJava  —  Configuração Inicial" />
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox spacing="12" maxWidth="480">
            <padding><Insets top="30" right="50" bottom="30" left="50"/></padding>

            <Label text="Bem-vindo! Configure os dados do restaurante para começar."
                   styleClass="subtitulo" wrapText="true"/>

            <Separator/>
            <Label text="Dados do Restaurante" styleClass="titulo-secao"/>

            <TextField fx:id="tfNome"      promptText="Nome fantasia *"                styleClass="text-field"/>
            <TextField fx:id="tfCnpj"      promptText="CNPJ (só números) *"            styleClass="text-field"/>
            <TextField fx:id="tfEndereco"  promptText="Endereço completo *"            styleClass="text-field"/>
            <TextField fx:id="tfTelefone"  promptText="Telefone"                       styleClass="text-field"/>
            <TextField fx:id="tfCategoria" promptText="Categoria culinária (ex: Nordestina)" styleClass="text-field"/>

            <Separator/>
            <Label text="Conta do Gerente" styleClass="titulo-secao"/>

            <TextField     fx:id="tfNomeGerente" promptText="Nome do gerente *"                        styleClass="text-field"/>
            <TextField     fx:id="tfEmail"        promptText="E-mail *"                                styleClass="text-field"/>
            <PasswordField fx:id="tfSenha"        promptText="Senha (mín. 8 chars + 1 número) *"      styleClass="password-field"/>

            <Separator/>

            <Button fx:id="btnSalvar" text="Salvar e Continuar"
                    styleClass="btn-primary" maxWidth="Infinity"
                    onAction="#salvar"/>
        </VBox>
    </ScrollPane>
</VBox>
