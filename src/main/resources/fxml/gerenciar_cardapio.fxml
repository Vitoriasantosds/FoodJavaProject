<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.ads.foodjava.view.fxml.GerenciarCardapioController"
            stylesheets="@../css/estilo.css"
            prefWidth="800" prefHeight="600">

    <!-- Cabeçalho -->
    <top>
        <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="10">
            <Label text="🍴 FoodJava  —  Cardápio"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Painel" styleClass="btn-secondary" onAction="#voltarPainel"/>
        </HBox>
    </top>

    <!-- Formulário de adição (esquerda) -->
    <left>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane" prefWidth="300">
            <VBox spacing="10"
                  style="-fx-background-color:#fafafa; -fx-border-color:#e0e0e0; -fx-border-width:0 1 0 0;">
                <padding><Insets top="20" right="18" bottom="20" left="18"/></padding>

                <Label text="Novo Item" styleClass="titulo-secao"/>
                <Separator/>

                <TextField  fx:id="tfNomeItem"  promptText="Nome *"              styleClass="text-field"/>
                <TextField  fx:id="tfDescItem"  promptText="Descrição"           styleClass="text-field"/>
                <TextField  fx:id="tfPrecoItem" promptText="Preço (ex: 19.90) *" styleClass="text-field"/>

                <ComboBox   fx:id="cbCategoriaItem" promptText="Categoria *"
                            maxWidth="Infinity" styleClass="combo-box"/>

                <CheckBox   fx:id="cbDisponivelItem" text="Disponível" selected="true"/>

                <HBox spacing="6" alignment="CENTER_LEFT">
                    <TextField fx:id="tfImagemItem" promptText="Caminho da imagem"
                               styleClass="text-field" HBox.hgrow="ALWAYS"/>
                    <Button text="📁" onAction="#selecionarImagem"
                            style="-fx-padding:9 12; -fx-background-radius:5;"/>
                </HBox>

                <Button text="+ Adicionar Item" styleClass="btn-primary" maxWidth="Infinity"
                        onAction="#adicionarItem"/>

                <Separator/>
                <Label text="Importar" styleClass="titulo-secao"/>

                <Button text="Importar JSON" styleClass="btn-secondary" maxWidth="Infinity"
                        onAction="#importarJson"/>
            </VBox>
        </ScrollPane>
    </left>

    <!-- Lista de itens (centro) -->
    <center>
        <VBox spacing="0">
            <!-- Barra de pesquisa -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color:white; -fx-border-color:#e0e0e0; -fx-border-width:0 0 1 0;">
                <padding><Insets top="10" right="16" bottom="10" left="16"/></padding>
                <TextField fx:id="tfBuscaItem" promptText="Buscar item..."
                           styleClass="text-field" HBox.hgrow="ALWAYS"
                           onKeyReleased="#buscar"/>
                <ComboBox  fx:id="cbFiltroCat" promptText="Todas as categorias"
                           styleClass="combo-box" prefWidth="190" onAction="#buscar"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="scroll-pane">
                <VBox fx:id="boxItens" spacing="10">
                    <padding><Insets top="14" right="16" bottom="14" left="16"/></padding>
                </VBox>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
